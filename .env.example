# =============================================================================
# AZSploitMapper Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Azure Service Principal (REQUIRED for scanning) ---
# Create a Service Principal with Reader role on the target subscription:
#   az ad sp create-for-rbac --name "AZSploitMapper" --role Reader \
#     --scopes /subscriptions/YOUR_SUBSCRIPTION_ID
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# --- AZSploitMapper API Key (REQUIRED for web dashboard access) ---
# Generate with: python -m azsploitmapper generate-api-key --name "admin"
# The key is shown once at creation. Store it securely.
AZSPLOITMAPPER_API_KEY=

# --- Entra ID OAuth2 (OPTIONAL - for multi-user web authentication) ---
# Only needed if you want browser-based Microsoft sign-in.
# Leave empty to use API key authentication only.
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
AUTH_REDIRECT_URI=https://localhost:8443/auth/callback

# --- Server Configuration ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8443

# --- TLS Configuration ---
# Paths inside the container (mapped via docker-compose volumes)
TLS_CERT_PATH=/app/certs/cert.pem
TLS_KEY_PATH=/app/certs/key.pem

# --- Session Security ---
# Session lifetime in seconds (default: 8 hours)
SESSION_MAX_AGE=28800
# Maximum concurrent sessions per user (default: 5)
SESSION_MAX_COUNT=100

# --- Rate Limiting ---
# Requests per minute for scan endpoint (default: 5)
SCAN_RATE_LIMIT=5
# Requests per minute for general API (default: 60)
API_RATE_LIMIT=60

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
