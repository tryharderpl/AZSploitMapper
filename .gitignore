# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# TLS certificates (never commit private keys)
certs/*.key
certs/*.pem
!certs/README.md
.claude/
